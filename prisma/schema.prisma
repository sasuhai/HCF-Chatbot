generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Document {
  id        String   @id @default(cuid())
  title     String
  sourceUrl String?  @db.Text
  type      String
  content   String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("PENDING")
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String?
  sessionId String?
  platform  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  source    String?   @db.Text
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String       @db.LongText
  feedback       String?      // 'like' or 'dislike'
  parentId       String?      // For replies
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parent         Message?     @relation("Replies", fields: [parentId], references: [id], onDelete: SetNull)
  replies        Message[]    @relation("Replies")

  @@index([conversationId], map: "Message_conversationId_fkey")
  @@index([parentId], map: "Message_parentId_fkey")
}

model Lead {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  phone     String?
  source    String
  createdAt DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.LongText
  updatedAt DateTime @updatedAt
}
